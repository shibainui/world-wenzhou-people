---
import Base from '../layouts/Base.astro';
---

<Base title="关于">
  <div class="about-page">
    <div class="about-content">
      <div class="section-divider"></div>
      <h2>关于本项目</h2>
      <p class="en-sub">About This Project</p>
      <p>世界温州人是一个展示温州全球移民社群文化与历史的数字展览项目。我们希望通过文字与影像，讲述温州人在全球各地的故事，记录他们的奋斗与成就。</p>
      <p class="en-sub" style="text-transform:none;letter-spacing:0;font-weight:400;font-size:0.9rem;">World Wenzhou People is a digital exhibition project showcasing the culture and history of Wenzhou's global diaspora. Through words and images, we tell the stories of Wenzhou people around the world.</p>

      <h3 style="margin-top:3rem;">联系我们</h3>
      <p class="en-sub">Contact</p>
      <p>如有任何问题或合作意向，欢迎联系我们。</p>
      <p class="en-sub" style="text-transform:none;letter-spacing:0;font-weight:400;font-size:0.9rem;">For inquiries or collaboration, please reach out.</p>
      <p style="margin-top:1.5rem;">邮箱 Email: <a href="mailto:hello@worldwenzhou.com">hello@worldwenzhou.com</a></p>
    </div>
  </div>
</Base>

<style>
  .about-page {
    padding-top: calc(var(--nav-height) + 6rem);
    padding-bottom: 6rem;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .section-divider {
    width: 56px;
    height: 3px;
    background: var(--color-accent);
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .about-content h2 {
    margin-bottom: 0.25rem;
  }

  .about-content h3 {
    margin-bottom: 0.25rem;
  }
</style>
