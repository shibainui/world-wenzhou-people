---
interface Props {
  activePage?: string;
}

const { activePage = '/' } = Astro.props;

const links = [
  { href: '/', label: '首页' },
  { href: '/history', label: '历史' },
  { href: '/business', label: '商业' },
  { href: '/culture', label: '文化' },
  { href: '/about', label: '关于' },
];
---

<nav id="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-zh">世界温州人</span>
      <span class="logo-en">World Wenzhou</span>
    </a>
    <ul class="nav-links">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={{ active: activePage === href }}
            aria-current={activePage === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <button class="hamburger" id="hamburger" aria-label="菜单" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 100%);
  }

  nav.scrolled {
    background: rgba(255, 255, 255, 0.85);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }

  /* Hero state: white text on dark photos */
  nav:not(.scrolled) .logo-zh {
    color: #fff;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }
  nav:not(.scrolled) .logo-en {
    color: rgba(255,255,255,0.7);
  }
  nav:not(.scrolled) .nav-links a {
    color: rgba(255,255,255,0.9);
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  nav:not(.scrolled) .nav-links a:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }
  nav:not(.scrolled) .hamburger span {
    background: #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }

  /* Scrolled state: dark text with glass background */
  nav.scrolled .logo-zh { color: var(--color-text); text-shadow: none; }
  nav.scrolled .logo-en { color: var(--color-text-muted); }
  nav.scrolled .nav-links a { color: var(--color-text); text-shadow: none; }
  nav.scrolled .nav-links a:hover { background: var(--color-accent-light); color: var(--color-accent); }
  nav.scrolled .nav-links a.active { background: var(--color-accent-light); color: var(--color-accent); font-weight: 600; }
  nav.scrolled .hamburger span { background: var(--color-text); box-shadow: none; }

  /* Hero state active link */
  nav:not(.scrolled) .nav-links a.active {
    background: rgba(255,255,255,0.2);
    color: #fff;
    font-weight: 600;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    gap: 1px;
  }

  .logo-zh {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.2;
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }

  .logo-en {
    font-family: var(--font-en);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.4s ease;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
  }

  .nav-links a {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 1px;
    transition: transform 0.3s ease, background 0.4s ease;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 1rem;
      gap: 0.25rem;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
      border-radius: 0 0 var(--radius) var(--radius);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      padding: 0.75rem 1rem;
      border-radius: 8px;
    }

    /* Mobile menu always uses dark text since it has white background */
    .nav-links.open a { color: var(--color-text) !important; text-shadow: none !important; }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const hamburger = document.getElementById('hamburger');
  const links = nav?.querySelector('.nav-links');

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        nav?.classList.toggle('scrolled', window.scrollY > 50);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  hamburger?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('open') ?? false;
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && links?.classList.contains('open')) {
      links.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.focus();
    }
  });
</script>
