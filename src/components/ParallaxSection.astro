---
interface Props {
  bgImage: string;
  headingZh: string;
  headingEn: string;
  dark?: boolean;
  level?: 1 | 2 | 3;
}

const { bgImage, headingZh, headingEn, dark = false, level = 2 } = Astro.props;
const HeadingTag = `h${level}` as keyof HTMLElementTagNameMap;
const base = import.meta.env.BASE_URL;
const imageUrl = bgImage.startsWith('/') ? `${base}${bgImage.slice(1)}` : `${base}${bgImage}`;
---

<section
  class="parallax-section"
  class:list={{ 'theme-dark': dark, 'theme-light': !dark }}
>
  <div class="parallax-bg" data-parallax-bg style={`background-image: url(${imageUrl});`}></div>
  <div class="section-gradient"></div>
  <div class="parallax-content">
    <div class="section-divider"></div>
    <HeadingTag class="section-heading">{headingZh}</HeadingTag>
    <p class="section-en">{headingEn}</p>
    <div class="parallax-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .parallax-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .parallax-bg {
    position: absolute;
    inset: -20%;
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .section-gradient {
    position: absolute;
    inset: 0;
  }

  /* Dark theme: warm dark overlay for light text */
  .theme-dark .section-gradient {
    background: linear-gradient(
      180deg,
      rgba(12, 10, 9, 0.55) 0%,
      rgba(12, 10, 9, 0.35) 50%,
      rgba(12, 10, 9, 0.55) 100%
    );
  }

  .theme-dark .section-heading {
    color: #ffffff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .theme-dark .section-en {
    color: rgba(255, 255, 255, 0.65);
  }

  .theme-dark .parallax-body :global(p) {
    color: rgba(255, 255, 255, 0.88);
  }

  .theme-dark .parallax-body :global(.en-sub) {
    color: rgba(255, 255, 255, 0.55);
  }

  .theme-dark .section-divider {
    background: rgba(255, 255, 255, 0.4);
  }

  /* Light theme: strong white overlay for text readability on photos */
  .theme-light .section-gradient {
    background: linear-gradient(
      90deg,
      rgba(250, 250, 249, 0.88) 0%,
      rgba(250, 250, 249, 0.78) 40%,
      rgba(250, 250, 249, 0.45) 70%,
      rgba(250, 250, 249, 0.20) 100%
    );
  }

  .theme-light .section-heading {
    color: var(--color-text);
  }

  .theme-light .section-en {
    color: var(--color-accent);
  }

  .theme-light .parallax-body :global(p) {
    color: var(--color-text);
  }

  .theme-light .parallax-body :global(.en-sub) {
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.9rem;
    font-weight: 400;
  }

  .parallax-content {
    position: relative;
    z-index: 2;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 2rem;
    width: 100%;
  }

  .section-divider {
    width: 56px;
    height: 3px;
    background: var(--color-accent);
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .section-en {
    font-family: var(--font-en);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 2rem;
    color: var(--color-accent);
  }

  .parallax-body {
    max-width: 600px;
  }

  /* CTA links inside parallax sections */
  .parallax-body :global(.cta-link) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.25s ease;
    background: transparent;
  }

  .parallax-body :global(.cta-link:hover) {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #ffffff;
  }

  .theme-dark .parallax-body :global(.cta-link) {
    border-color: rgba(255, 255, 255, 0.25);
    color: #ffffff;
  }

  .theme-dark .parallax-body :global(.cta-link:hover) {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .parallax-section {
      min-height: 80vh;
    }

    .parallax-content {
      padding: 4rem 1.5rem;
    }
  }
</style>
